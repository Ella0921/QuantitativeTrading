# Copy this file to .env and fill in your values
# Never commit .env to git

# MLflow tracking server (default: local mlruns/)
MLFLOW_TRACKING_URI=mlruns

# Default tickers for training
DEFAULT_TICKERS=^TWII,2330.TW,AAPL,TSLA

# Training defaults
DEFAULT_TRAIN_START=2016-01-01
DEFAULT_TRAIN_END=2022-12-31
DEFAULT_TEST_START=2023-01-01
DEFAULT_TEST_END=2024-12-31
DEFAULT_INITIAL_CAPITAL=1000000
